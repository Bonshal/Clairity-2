{
    "name": "market-research-api",
    "version": "1.0.0",
    "description": "Node.js API Gateway for the Market Research Platform",
    "main": "dist/index.js",
    "scripts": {
        "dev": "nodemon --exec ts-node src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "db:migrate": "prisma migrate dev",
        "db:push": "prisma db push",
        "db:generate": "prisma generate",
        "lint": "eslint src --ext .ts"
    },
    "dependencies": {
        "@prisma/client": "^6.3.0",
        "@upstash/redis": "^1.34.0",
        "bullmq": "^5.30.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "helmet": "^8.0.0",
        "jsonwebtoken": "^9.0.2",
        "node-cron": "^3.0.3",
        "socket.io": "^4.8.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^22.0.0",
        "@types/node-cron": "^3.0.11",
        "nodemon": "^3.1.0",
        "prisma": "^6.3.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.0"
    }
}